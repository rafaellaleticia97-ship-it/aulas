.q-num{font-family:var(--mono);font-size:10px;color:var(--accent);letter-spacing:.1em;margin-bottom:.75rem}
.q-txt{font-size:16px;color:var(--ink);line-height:1.6;margin-bottom:1.25rem;font-family:var(--heading);font-weight:600}
.q-inner{display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap}
.q-opts-col{flex:1;min-width:200px}
