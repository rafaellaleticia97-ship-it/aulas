.q-exp.open{display:block}
footer{text-align:center;padding:2rem 0;font-family:var(--mono);font-size:11px;color:var(--muted);border-top:1px solid var(--border);margin-top:3rem;position:relative;z-index:10}
@keyframes up{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
@keyframes fadein{from{opacity:0}to{opacity:1}}
