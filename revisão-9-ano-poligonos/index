.sc-card{text-align:center;background:var(--paper);border:1.5px solid var(--border);border-radius:12px;padding:1rem 1.5rem;min-width:100px;box-shadow:0 2px 10px rgba(59,91,219,.06)}
.sc-num{font-family:var(--heading);font-size:2.2rem;font-weight:900;color:var(--accent);line-height:1}
.sc-lbl{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-top:4px}
