.tf-item.revealed .tf-badge{display:block}
.tf-item.revealed[data-a="V"] .tf-badge{background:#c3f0d8;color:#0a5c3a}
.tf-item.revealed[data-a="F"] .tf-badge{background:#ffd0d0;color:#7a0000}
.tf-exp{display:none;font-size:13px;color:var(--muted);margin-top:5px;font-style:italic}
.tf-item.revealed .tf-exp{display:block}
.quiz-hdr{text-align:center;padding:3rem 0 2rem;border-top:2px solid var(--border)}
