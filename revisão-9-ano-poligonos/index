.concept{background:var(--paper);border:1.5px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:0 2px 12px rgba(59,91,219,.06)}
.c-tag{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:.6rem}
.concept p{font-size:15px;color:var(--muted);line-height:1.8}
.formula{background:linear-gradient(135deg,#eef2ff 0%,#e0e7ff 100%);border:1.5px solid var(--border2);border-radius:12px;padding:1.25rem 1.5rem;margin:1.25rem 0;font-family:var(--mono);font-size:1.15rem;color:var(--accent);box-shadow:0 2px 8px rgba(59,91,219,.1);position:relative;overflow:hidden}
