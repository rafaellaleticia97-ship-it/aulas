<style>
:root{--bg:#f0f4ff;--paper:#ffffff;--surface:#f7f9ff;--surface2:#eef2ff;--border:#dde3f5;--border2:#b8c4e8;--ink:#1a1e3a;--muted:#5a6490;--accent:#3b5bdb;--accent2:#0ca678;--gold:#e8900a;--red:#d63939;--green:#099268;--heading:'Nunito',sans-serif;--body:'Crimson Pro',serif;--mono:'JetBrains Mono',monospace}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:var(--body);font-size:17px;line-height:1.75;min-height:100vh;overflow-x:hidden;position:relative}
#geo-bg{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}#geo-bg svg{width:100%;height:100%}
.ffml{position:fixed;font-family:var(--mono);font-size:13px;color:#3b5bdb;opacity:.11;pointer-events:none;z-index:1;white-space:nowrap;animation:drift linear infinite}
@keyframes drift{0%{transform:translateY(0) rotate(var(--r))}100%{transform:translateY(-120vh) rotate(var(--r))}}
#prog{position:fixed;top:0;left:0;height:3px;background:var(--accent);z-index:300;transition:width .15s;border-radius:0 2px 2px 0}
#sidebar{position:fixed;left:0;top:0;width:230px;height:100vh;background:rgba(255,255,255,.96);backdrop-filter:blur(14px);border-right:1px solid var(--border);padding:2rem 1.25rem;z-index:200;transform:translateX(-230px);transition:transform .3s cubic-bezier(.4,0,.2,1);overflow-y:auto;box-shadow:4px 0 20px rgba(59,91,219,.07)}
#sidebar.open{transform:translateX(0)}
#toggle{position:fixed;left:1rem;top:1rem;z-index:210;background:var(--accent);border:none;color:#fff;width:36px;height:36px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px rgba(59,91,219,.35)}
.sb-title{font-family:var(--heading);font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:1px solid var(--border)}
.sb-nav{list-style:none}.sb-nav li{margin-bottom:2px}
.sb-nav a{display:flex;align-items:center;gap:8px;font-family:var(--heading);font-size:13px;font-weight:600;color:var(--muted);text-decoration:none;padding:7px 10px;border-radius:8px;transition:all .12s}
.sb-nav a:hover,.sb-nav a.act{background:var(--surface2);color:var(--accent)}
.sb-nav .n{font-family:var(--mono);font-size:10px;color:var(--accent);min-width:22px}
main{max-width:820px;margin:0 auto;padding:0 2rem 8rem;position:relative;z-index:10}
.hero{padding:6.5rem 0 3rem}
.hero-tag{font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem;opacity:0;animation:up .6s .1s forwards}
.hero-h1{font-family:var(--heading);font-size:clamp(3rem,8vw,5.5rem);font-weight:900;line-height:.95;letter-spacing:-.03em;color:var(--ink);opacity:0;animation:up .7s .2s forwards}
.hero-h1 em{font-style:normal;color:var(--accent)}
.hero-desc{margin-top:1.5rem;font-size:17px;color:var(--muted);max-width:520px;opacity:0;animation:up .7s .35s forwards}
.hero-pills{display:flex;flex-wrap:wrap;gap:8px;margin-top:2rem;opacity:0;animation:up .7s .45s forwards}
.pill{font-family:var(--mono);font-size:11px;padding:5px 14px;border:1.5px solid var(--border2);border-radius:20px;color:var(--accent);background:rgba(59,91,219,.06)}
.hero-line{height:2px;background:linear-gradient(to right,var(--accent),#6ea8fe,transparent);margin-top:2.5rem;border-radius:2px;opacity:0;animation:fadein 1s .6s forwards}
